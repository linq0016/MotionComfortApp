    "dashboard.audio_mode.supporting_copy" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Research shows that sound at 100Hz can help alleviate vehicle motion sickness."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "研究表明频率为100Hz的声音可以缓解晕车不适。"
          }
        }
      }
    },
    "dashboard.mode.dynamic.subtitle" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traverse the cosmos, with stars pulsing to the rhythm of your ride, echoing your senses."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "穿梭宇宙，星点随旅程起伏而跃动，\n呼应你的每一次体感波动。"
          }
        }
      }
    },
    "dashboard.mode.live_view.subtitle" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "See the real world through the view-finder with calming effects around the edge."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通过相机取景器观察世界，\n景随意动，安享行程。"
          }
        }
      }
    },
    "dashboard.mode.minimal.subtitle" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Simple peripheral guidance with a clean and lightweight design, visualizing motions."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "简约轻量的视觉引导，\n体感波动具像化。"
