    "liveview.status.denied.headline" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Camera access denied"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "相机访问已被拒绝"
          }
        }
      }
    },
    "liveview.status.denied.note" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Camera access is currently denied, so the live-view session stays on this placeholder."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当前相机访问被拒绝，因此 Live View 会停留在此占位界面。"
          }
        }
      }
    },
    "liveview.status.denied.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DENIED"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已拒绝"
          }
        }
      }
    },
    "liveview.status.not_determined.headline" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Camera permission pending"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "等待相机权限"
          }
        }
      }
    },
    "liveview.status.not_determined.note" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app can request camera access now. Once granted, the live-view session will switch into the real camera preview."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App 现在可以请求相机权限。获得授权后，Live View 会切换到真实相机预览。"
          }
        }
      }
    },
    "liveview.status.not_determined.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "REQUEST"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请求权限"
          }
        }
      }
    },
