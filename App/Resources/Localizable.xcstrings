    "dashboard.mode.dynamic.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Richer motion cues with the current dynamic fullscreen visuals unchanged."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更丰富的动态运动提示，同时保留当前已调好的 Dynamic 全屏视觉体验。"
          }
        }
      }
    },
    "dashboard.mode.live_view.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Launch the existing camera-based fullscreen guidance without changing its behavior."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "进入现有基于相机的全屏引导体验，不改变其当前行为。"
          }
        }
      }
    },
    "dashboard.mode.minimal.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stable peripheral guidance with a clean and lightweight fullscreen session."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "简洁轻量的全屏体验，提供稳定的周边视觉引导。"
          }
        }
      }
    },
    "dashboard.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose a visual mode to start the exact fullscreen session experience you already tuned."
