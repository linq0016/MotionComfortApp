    "dashboard.audio_mode.supporting_copy" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Research shows that exposure to sound at 100Hz can help alleviate vehicle motion sickness."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "研究表明音高100Hz的声音可以缓解晕动症。"
          }
        }
      }
    },
