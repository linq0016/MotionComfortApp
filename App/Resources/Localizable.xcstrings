    },
    "dashboard.subtitle" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Real-time dynamic particles visualize acceleration, ease visual-sensory conflicts, and make every ride more comfortable."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通过实时响应的动态粒子，捕捉行车加速度变化，匹配体感节奏并消解视觉感官冲突，赋予每段行程更舒适的乘坐体验。"
          }
        }
      }
    },
